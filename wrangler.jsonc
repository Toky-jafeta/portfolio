{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2025-10-13",
  "pages_build_output_dir": "./build",
  "assets": {
    "directory": "./build",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
